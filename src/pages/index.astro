---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";

import Logo from "../assets/launchbed_purple.png";
import HeaderBG from "../assets/header_bg.jpg";

const projects = await getCollection("projects");
projects.sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <nav
    class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-200 bg-white/80 backdrop-blur-md"
  >
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <h1 class="flex items-center gap-2">
        <Image src={Logo} alt="Launchbed Technology" width={40} height={40} />
        <span class="text-xl font-bold tracking-tight"
          >Launchbed Technology</span
        >
      </h1>
      <div class="hidden items-center gap-6 sm:flex">
        <a
          href="#servicios"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Servicios</a
        >
        <a
          href="#proyectos"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Proyectos</a
        >
        <a
          href="#contacto"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Contacto</a
        >
      </div>
    </div>
  </nav>

  <section
    class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-20 text-center"
  >
    <Image
      src={HeaderBG}
      alt="Fondo de tecnología"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-black/50"></div>

    <h1
      class="relative mb-4 text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl text-white"
    >
      Launchbed Technology
    </h1>
    <p class="relative mb-8 max-w-xl text-lg text-gray-200">
      Creamos landing pages y sitios web modernos, rápidos y optimizados para tu
      negocio.
    </p>
    <div class="relative flex flex-wrap justify-center gap-4">
      <a
        href="#contacto"
        class="rounded-xl bg-primary px-6 py-3 text-sm font-medium text-white transition hover:bg-primary-hover"
      >
        Contáctanos
      </a>
      <a
        href="#proyectos"
        class="rounded-xl border border-zinc-300 text-gray-200 px-6 py-3 text-sm font-medium transition hover:bg-zinc-100 hover:text-zinc-700"
      >
        Ver proyectos
      </a>
    </div>
  </section>

  <section id="servicios" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-4 text-center text-3xl font-bold">Servicios</h2>
      <p class="mb-12 text-center text-zinc-600">
        Transformamos tus ideas en experiencias digitales efectivas.
      </p>
      <div class="grid gap-8 md:grid-cols-2">
        <div
          class="rounded-2xl border border-primary p-8 text-center transition hover:shadow-md"
        >
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-xl bg-primary text-white"
          >
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-device-imac"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M3 4a1 1 0 0 1 1 -1h16a1 1 0 0 1 1 1v12a1 1 0 0 1 -1 1h-16a1 1 0 0 1 -1 -1v-12"
              ></path><path d="M3 13h18"></path><path d="M8 21h8"></path><path
                d="M10 17l-.5 4"></path><path d="M14 17l.5 4"></path></svg
            >
          </div>
          <h3 class="mb-2 text-xl font-semibold">Landing Pages</h3>
          <p class="text-zinc-600">
            Páginas diseñadas para convertir visitantes en clientes. Rápidas,
            responsivas y optimizadas para SEO.
          </p>
        </div>
        <div
          class="rounded-2xl border border-primary p-8 text-center transition hover:shadow-md"
        >
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-xl bg-primary text-white"
          >
            <svg
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-world"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"></path><path
                d="M3.6 9h16.8"></path><path d="M3.6 15h16.8"></path><path
                d="M11.5 3a17 17 0 0 0 0 18"></path><path
                d="M12.5 3a17 17 0 0 1 0 18"></path></svg
            >
          </div>
          <h3 class="mb-2 text-xl font-semibold">Sitios Web</h3>
          <p class="text-zinc-600">
            Sitios web completos y profesionales con CMS, blog, catálogo y más.
            Escalables y fáciles de mantener.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="proyectos" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-4 text-center text-3xl font-bold">Proyectos</h2>
      <p class="mb-12 text-center text-zinc-600">
        Algunos de los proyectos que hemos realizado.
      </p>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section id="contacto" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="mb-4 text-3xl font-bold">Contacto</h2>
      <p class="mb-12 text-zinc-600">¿Tienes un proyecto en mente? Hablemos.</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a
          href="mailto:launchbed.technology@gmail.com"
          class="inline-flex items-center gap-3 rounded-xl border border-zinc-300 px-6 py-4 text-sm font-medium transition hover:bg-zinc-100"
        >
          <svg
            class="h-5 w-5 text-zinc-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
          launchbed.technology@gmail.com
        </a>
        <a
          href="https://wa.me/59177406837"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-zinc-300 px-6 py-4 text-sm font-medium transition hover:bg-zinc-100"
        >
          <svg
            class="h-5 w-5 text-green-600"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
            ></path>
          </svg>
          +591 77406837
        </a>
      </div>
    </div>
  </section>

  <footer
    class="border-t border-zinc-200 bg-primary px-6 py-8 text-center text-sm text-gray-200"
  >
    &copy; {new Date().getFullYear()} Launchbed Technology. Todos los derechos reservados.
  </footer>
</Layout>
