---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";

import Logo from "../assets/launchbed_purple.png";
import HeaderBG from "../assets/header_bg.jpg";

const projects = [
  {
    title: "TechFlow",
    shortDesc:
      "Plataforma SaaS con panel de administración y landing page conversional.",
    fullDesc:
      "Desarrollamos una plataforma SaaS completa con landing page optimizada para conversiones, panel de administración intuitivo y una experiencia de usuario fluida. El diseño minimalista y las animaciones sutiles mejoran la retención de usuarios.",
    tags: ["Landing Page", "SaaS", "React"],
    link: "https://ejemplo.com/techflow",
  },
  {
    title: "GreenLeaf Organics",
    shortDesc: "Sitio web corporativo para marca de productos orgánicos.",
    fullDesc:
      "Sitio web corporativo con catálogo de productos, blog de recetas saludables y tienda online integrada. Diseño fresco y natural que refleja los valores de la marca.",
    tags: ["Sitio Web", "Ecommerce", "WordPress"],
  },
  {
    title: "FitHub Pro",
    shortDesc:
      "Landing page para aplicación de fitness con registro e información.",
    fullDesc:
      "Landing page moderna con secciones de características, planes de precios, testimonios y formulario de registro. Optimizada para SEO y carga rápida en dispositivos móviles.",
    tags: ["Landing Page", "Fitness", "Next.js"],
    link: "https://ejemplo.com/fithub",
  },
  {
    title: "Studio Noir",
    shortDesc: "Portfolio interactivo para estudio de producción audiovisual.",
    fullDesc:
      "Portfolio interactivo con galería de proyectos, reproductor de video integrado y animaciones cinematográficas. Experiencia inmersiva que destaca el trabajo creativo del estudio.",
    tags: ["Sitio Web", "Portfolio", "Astro"],
  },
];
---

<Layout>
  <nav
    class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-200 bg-white/80 backdrop-blur-md"
  >
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <h1 class="flex items-center gap-2">
        <Image src={Logo} alt="Launchbed Technology" width={40} height={40} />
        <span class="text-xl font-bold tracking-tight"
          >Launchbed Technology</span
        >
      </h1>
      <div class="hidden items-center gap-6 sm:flex">
        <a
          href="#servicios"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Servicios</a
        >
        <a
          href="#proyectos"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Proyectos</a
        >
        <a
          href="#contacto"
          class="text-sm text-zinc-600 transition hover:text-zinc-900"
          >Contacto</a
        >
      </div>
    </div>
  </nav>

  <section
    class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6 pt-20 text-center"
  >
    <Image
      src={HeaderBG}
      alt="Fondo de tecnología"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-black/50"></div>

    <h1
      class="relative mb-4 text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl text-white"
    >
      Launchbed Technology
    </h1>
    <p class="relative mb-8 max-w-xl text-lg text-gray-200">
      Creamos landing pages y sitios web modernos, rápidos y optimizados para tu
      negocio.
    </p>
    <div class="relative flex flex-wrap justify-center gap-4">
      <a
        href="#contacto"
        class="rounded-xl bg-primary px-6 py-3 text-sm font-medium text-white transition hover:bg-primary-hover"
      >
        Contáctanos
      </a>
      <a
        href="#proyectos"
        class="rounded-xl border border-zinc-300 text-gray-200 px-6 py-3 text-sm font-medium transition hover:bg-zinc-100 hover:text-zinc-700"
      >
        Ver proyectos
      </a>
    </div>
  </section>

  <section id="servicios" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-4 text-center text-3xl font-bold">Servicios</h2>
      <p class="mb-12 text-center text-zinc-600">
        Transformamos tus ideas en experiencias digitales efectivas.
      </p>
      <div class="grid gap-8 md:grid-cols-2">
        <div
          class="rounded-2xl border border-zinc-200 p-8 text-center transition hover:shadow-md"
        >
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-xl bg-violet-100"
          >
            <svg
              class="h-8 w-8 text-violet-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25"
              ></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-semibold">Landing Pages</h3>
          <p class="text-zinc-600">
            Páginas diseñadas para convertir visitantes en clientes. Rápidas,
            responsivas y optimizadas para SEO.
          </p>
        </div>
        <div
          class="rounded-2xl border border-zinc-200 p-8 text-center transition hover:shadow-md"
        >
          <div
            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-xl bg-sky-100"
          >
            <svg
              class="h-8 w-8 text-sky-600"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-semibold">Sitios Web</h3>
          <p class="text-zinc-600">
            Sitios web completos y profesionales con CMS, blog, catálogo y más.
            Escalables y fáciles de mantener.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="proyectos" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-4 text-center text-3xl font-bold">Proyectos</h2>
      <p class="mb-12 text-center text-zinc-600">
        Algunos de los proyectos que hemos realizado.
      </p>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
        {
          projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))
        }
      </div>
    </div>
  </section>

  <section id="contacto" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="mb-4 text-3xl font-bold">Contacto</h2>
      <p class="mb-12 text-zinc-600">¿Tienes un proyecto en mente? Hablemos.</p>
      <div class="flex flex-wrap justify-center gap-6">
        <a
          href="mailto:contacto@launchbed.tech"
          class="inline-flex items-center gap-3 rounded-xl border border-zinc-300 px-6 py-4 text-sm font-medium transition hover:bg-zinc-100"
        >
          <svg
            class="h-5 w-5 text-zinc-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
          contacto@launchbed.tech
        </a>
        <a
          href="https://wa.me/521234567890"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-zinc-300 px-6 py-4 text-sm font-medium transition hover:bg-zinc-100"
        >
          <svg
            class="h-5 w-5 text-green-600"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
            ></path>
          </svg>
          +52 123 456 7890
        </a>
      </div>
    </div>
  </section>

  <footer
    class="border-t border-zinc-200 px-6 py-8 text-center text-sm text-zinc-500"
  >
    &copy; {new Date().getFullYear()} Launchbed Technology. Todos los derechos reservados.
  </footer>

  <!-- Detail Modal -->
  <!-- <dialog
    id="detail-modal"
    class="fixed inset-0 z-50 flex h-full w-full items-center justify-center bg-transparent p-4 backdrop:bg-black/50 open:flex"
  >
    <div class="max-h-[80vh] w-full max-w-lg overflow-y-auto rounded-2xl bg-white p-8 shadow-2xl">
      <div class="mb-4 h-48 rounded-lg bg-gradient-to-br from-zinc-100 to-zinc-200" />

      <h3 id="modal-title" class="mb-2 text-2xl font-bold"></h3>

      <div id="modal-tags" class="mb-4 flex flex-wrap gap-2"></div>

      <p id="modal-desc" class="mb-6 text-zinc-600 leading-relaxed"></p>

      <div id="modal-link" class="mb-6"></div>

      <button
        id="modal-close"
        class="cursor-pointer rounded-lg bg-zinc-900 px-6 py-2 text-sm font-medium text-white transition hover:bg-zinc-700"
      >
        Cerrar
      </button>
    </div>
  </dialog> -->
</Layout>

<script>
  const projectsData = [
    {
      title: "TechFlow",
      fullDesc:
        "Desarrollamos una plataforma SaaS completa con landing page optimizada para conversiones, panel de administración intuitivo y una experiencia de usuario fluida. El diseño minimalista y las animaciones sutiles mejoran la retención de usuarios.",
      tags: ["Landing Page", "SaaS", "React"],
      link: "https://ejemplo.com/techflow",
    },
    {
      title: "GreenLeaf Organics",
      fullDesc:
        "Sitio web corporativo con catálogo de productos, blog de recetas saludables y tienda online integrada. Diseño fresco y natural que refleja los valores de la marca.",
      tags: ["Sitio Web", "Ecommerce", "WordPress"],
    },
    {
      title: "FitHub Pro",
      fullDesc:
        "Landing page moderna con secciones de características, planes de precios, testimonios y formulario de registro. Optimizada para SEO y carga rápida en dispositivos móviles.",
      tags: ["Landing Page", "Fitness", "Next.js"],
      link: "https://ejemplo.com/fithub",
    },
    {
      title: "Studio Noir",
      fullDesc:
        "Portfolio interactivo con galería de proyectos, reproductor de video integrado y animaciones cinematográficas. Experiencia inmersiva que destaca el trabajo creativo del estudio.",
      tags: ["Sitio Web", "Portfolio", "Astro"],
    },
  ];

  const modal = document.getElementById("detail-modal");
  const modalTitle = document.getElementById("modal-title");
  const modalDesc = document.getElementById("modal-desc");
  const modalTags = document.getElementById("modal-tags");
  const modalLink = document.getElementById("modal-link");
  const modalClose = document.getElementById("modal-close");

  document.querySelectorAll("[data-open-detail]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const index = Number(btn.dataset.openDetail);
      const project = projectsData[index];
      if (!project) return;

      modalTitle.textContent = project.title;
      modalDesc.textContent = project.fullDesc;
      modalTags.innerHTML = project.tags
        .map(
          (t) =>
            `<span class="rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-600">${t}</span>`,
        )
        .join("");

      if (project.link) {
        modalLink.innerHTML = `<a href="${project.link}" target="_blank" rel="noopener noreferrer" class="inline-block rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium transition hover:bg-zinc-100">Visitar sitio web</a>`;
      } else {
        modalLink.innerHTML = "";
      }

      modal.showModal();
    });
  });

  modalClose.addEventListener("click", () => modal.close());

  modal.addEventListener("click", (e) => {
    if (e.target === modal) modal.close();
  });
</script>
