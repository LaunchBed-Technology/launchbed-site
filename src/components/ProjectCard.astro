---
import { Image } from "astro:assets";

const { project } = Astro.props;
const { title, shortDesc, cover } = project.data;
---

<a
  href={`/proyectos/${project.id}`}
  class="group block rounded-2xl border border-primary bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md"
>
  <div class="mb-4 h-48 overflow-hidden rounded-lg bg-zinc-100">
    <Image
      src={cover}
      alt={title}
      width={400}
      height={300}
      class="h-full w-full object-cover transition group-hover:scale-105"
    />
  </div>

  <h3 class="mb-2 text-xl font-semibold">{title}</h3>
  <p class="text-zinc-600">{shortDesc}</p>
</a>
